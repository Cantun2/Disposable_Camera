# Copy to .env.local and fill in with your Supabase project values.
# All keys are exposed to the browser (Vite inlines VITE_* at build time) — the
# anon key is public BY DESIGN. Real security lives in Supabase Auth + the RLS
# policies in supabase/schema.sql, not in these values.

# Project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# The public "anon" key (Project Settings → API). Safe to ship to the client.
VITE_SUPABASE_ANON_KEY=

# Storage bucket name. Defaults to "photos" if omitted.
VITE_SUPABASE_BUCKET=photos
